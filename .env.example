# Database Configuration
DATABASE_URL=postgresql://connectly_user:connectly_password@localhost:5432/connectly

# Clerk Authentication Keys
# Get these from https://clerk.com/docs/quickstart/set-up-your-application
CLERK_SECRET_KEY=sk_test_your_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Session Management
SESSION_SECRET=your-random-secret-key-min-32-chars-long

# API Configuration
API_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000

# Frontend Configuration
VITE_APP_NAME=Connectly

# Node Environment
NODE_ENV=development

# Optional: API Server Port
PORT=3000

# Optional: Frontend Port
VITE_PORT=5173
