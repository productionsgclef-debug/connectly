#!/bin/bash

# =================================================================
# MASTER BUILD & GIT AUTOMATION: @productionsgclef
# Steps: Setup -> Verify -> Build -> Git Push
# =================================================================

set -e # Exit immediately on error

echo "🛠️  Phase 1: Setup & Initialization"

# 1. Add License
if [ ! -f LICENSE ]; then
    echo "📄 Generating LICENSE..."
    echo "MIT License. Copyright (c) $(date +%Y) @productionsgclef" > LICENSE
fi

# 2. Generate package-lock.json for all package.json files
echo "📦 Locking dependencies..."
find . -name "package.json" -not -path "*/node_modules/*" | while read pkg; do
    dir=$(dirname "$pkg")
    echo "   - Processing $dir"
    (cd "$dir" && npm install --package-lock-only)
done

# 3. Setup Fastlane metadata (from GitLab snippet 1895688)
echo "📸 Setting up Fastlane assets..."
METADATA_DIR="fastlane/metadata/android/en-US"
mkdir -p "$METADATA_DIR/images"
touch "$METADATA_DIR/images/icon.png"
echo "Production G Clef App Description" > "$METADATA_DIR/full_description.txt"
echo "Production G Clef" > "$METADATA_DIR/title.txt"

echo "🔍 Phase 2: Verification"
MISSING=0
for file in "LICENSE" "package-lock.json" "$METADATA_DIR/title.txt"; do
    if [ -f "$file" ]; then
        echo "✅ OK: $file"
    else
        echo "❌ MISSING: $file"
        MISSING=$((MISSING + 1))
    fi
done

if [ $MISSING -gt 0 ]; then
    echo "⚠️ Verification Failed! Missing core files."
    exit 1
fi

echo "🚀 Phase 3: Building Android App"
if command -v fastlane &> /dev/null; then
    bundle exec fastlane android build
else
    echo "⚠️ Fastlane not found locally. (Skipping local build; CI will handle this.)"
fi

echo "📂 Phase 4: Git Automation"
# Detect current branch (handles main vs master automatically)
BRANCH=$(git rev-parse --abbrev-ref HEAD)
echo "📍 Detected current branch: $BRANCH"

# Stage all changes
git add .

# Ensure the script itself stays executable in Git's index
git update-index --chmod=+x build_app.sh

# Commit and Push
git commit -m "feat: add master build automation and project verification"
git push origin "$BRANCH"

echo "✨ All tasks completed successfully and pushed to $BRANCH!"
